{
  "name": "postkit-validation-library",
  "version": "1.0.2",
  "description": "Validation helpers for PostKit post data",
  "type": "commonjs",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm test && npm run build"
  },
  "keywords": [
    "postkit",
    "validation",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YogiSunil/PostKit-Validation-Library.git"
  },
  "homepage": "https://github.com/YogiSunil/PostKit-Validation-Library#readme",
  "bugs": {
    "url": "https://github.com/YogiSunil/PostKit-Validation-Library/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.1"
  }
}
