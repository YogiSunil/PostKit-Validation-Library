{
  "name": "postkit-validation",
  "version": "1.0.0",
  "description": "Validation helpers for PostKit post data",
  "type": "commonjs",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
